{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "node scripts/copy-script.cjs && npm run dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Purview Audit eXporter (PAX)",
    "version": "1.0.0"
  },
  "tauri": {
    "allowlist": {
      "shell": {
        "open": true
      },
      "dialog": {
        "open": true,
        "save": true,
        "confirm": true
      },
      "fs": {
        "all": true,
        "scope": ["**"]
      },
      "path": {
        "all": true
      }
    },
    "windows": [
      {
        "title": "Purview Audit eXporter (PAX) (1.0.0)",
        "width": 640,
        "height": 860,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "bundle": {
      "identifier": "com.microsoft.pax",
      "icon": [
        "icons/icon.png",
        "icons/icon.ico",
        "icons/icon.icns"
      ],
      "resources": []
    },
    "security": {
      "csp": null
    }
  }
}
