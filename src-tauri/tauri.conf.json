{
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "npm run dev",
    "devPath": "http://localhost:5173",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Portable Audit eXporter (PAX)",
    "version": "1.5.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false,
        "open": true
      },
      "dialog": {
        "all": false,
        "open": true,
        "save": true,
        "confirm": true
      },
      "fs": {
        "all": true,
        "scope": [
          "**"
        ]
      },
      "path": {
        "all": true
      }
    },
    "bundle": {
      "active": true,
      "identifier": "com.microsoft.pax",
      "icon": [
        "icons/icon.png",
        "icons/icon.ico",
        "icons/icon.icns"
      ],
      "resources": []
    },
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Portable Audit eXporter (PAX) v1.5.0",
        "width": 640,
        "height": 920,
        "minHeight": 600,
        "resizable": true
      }
    ]
  }
}
