{
  "name": "purview-audit-exporter",
  "version": "1.2.0",
  "description": "Cross-platform Purview audit export wizard (Tauri + React + TypeScript).",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "postbuild": "node scripts/verify-no-synthetic.cjs",
    "tauri": "tauri",
    "prebuild": "node scripts/copy-script.cjs",
    "build:macos": "npm run tauri build -- --target aarch64-apple-darwin && npm run tauri build -- --target x86_64-apple-darwin",
    "build:macos:silicon": "npm run tauri build -- --target aarch64-apple-darwin",
    "build:macos:intel": "npm run tauri build -- --target x86_64-apple-darwin",
    "synth:csv": "node scripts/generate-synthetic.mjs",
    "analyze:purview": "node scripts/analyze-purview-columns.mjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^1.6.0",
    "axios": "^1.7.2",
    "cheerio": "^1.0.0-rc.12",
    "clsx": "^2.1.0",
    "date-fns": "^3.6.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^1.6.0",
    "@types/node": "^20.14.9",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
